# cot-divergence environment variables.
# Copy this file to .env and fill in real values. .env is gitignored.
# Never commit real keys.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# Modal auth: DO NOT put MODAL_TOKEN_ID / MODAL_TOKEN_SECRET in .env.
# Run `modal setup` instead — it writes to ~/.modal.toml, which Modal's
# CLI reads automatically. Setting placeholder values in .env will
# override the valid tokens and break `modal deploy` with a confusing
# "Token ID is malformed" error.
