# Auto-generated by hatch-vcs at build time from the latest git tag.
# Should never be committed; the version comes from VCS.
src/cotsuite/_version.py

# Raw validation outputs mirror benchmarks/results policy — RUN.md and
# summary .json stay tracked; per-run JSONL blobs do not.
validation/*.jsonl
